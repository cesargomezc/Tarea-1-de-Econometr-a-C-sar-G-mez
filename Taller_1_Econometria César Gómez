        "## Pregunta 1.3 — Estimadores β via álgebra matricial *(8 pts.)*\n",
        "\n",
        "Calcule los estimadores MCO **manualmente**, usando la fórmula matricial:\n",
        "\n",
        "$$\\hat{\\boldsymbol{\\beta}} = (\\mathbf{X}^\\top \\mathbf{X})^{-1} \\mathbf{X}^\\top \\mathbf{y}$$\n",
        "\n",
        "**Sin usar** la función `lm()` de R."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "p1-3-code",
      "metadata": {
        "id": "p1-3-code",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "31df5e79-b649-4b6c-f1de-91a9dc2491f4"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Estimadores MCO (álgebra matricial):\n",
            "                  Estimador\n",
            "(Intercepto)     30.3078768\n",
            "hrs_sueno         1.3003464\n",
            "profesor_part     3.8976675\n",
            "media_sem_pasado  0.2586088\n",
            "tiempo_est        1.6779676\n",
            "asistencia        0.1146847\n",
            "nivel_socioec     2.6659308\n"
          ]
        }
      ],
      "source": [
        "# Pregunta 1.3: Estimadores beta via álgebra matricial (sin lm)\n",
        "\n",
        "# 1. Definir la matriz de diseño X (con columna de unos para el intercepto)\n",
        "X <- as.matrix(cbind(1, datos$hrs_sueno,\n",
        "                     datos$profesor_part,\n",
        "                     datos$media_sem_pasado,\n",
        "                     datos$tiempo_est,\n",
        "                     datos$asistencia,\n",
        "                     datos$nivel_socioec))\n",
        "\n",
        "# 2. Definir el vector de la variable dependiente y\n",
        "y <- as.matrix(datos$notas)\n",
        "\n",
        "# 3. Calcular X_transpuesta %*% X\n",
        "XtX <- t(X) %*% X\n",
        "\n",
        "# 4. Calcular la inversa de (X_transpuesta %*% X)\n",
        "XtX_inv <- solve(XtX)\n",
        "\n",
        "# 5. Calcular X_transpuesta %*% y\n",
        "XtY <- t(X) %*% y\n",
        "\n",
        "# 6. Calcular los estimadores beta_hat\n",
        "beta_hat <- XtX_inv %*% XtY\n",
        "\n",
        "# Imprimir los resultados\n",
        "colnames(beta_hat) <- c(\"Estimador\")\n",
        "rownames(beta_hat) <- c(\"(Intercepto)\",\n",
        "                         \"hrs_sueno\",\n",
        "                         \"profesor_part\",\n",
        "                         \"media_sem_pasado\",\n",
        "                         \"tiempo_est\",\n",
        "                         \"asistencia\",\n",
        "                         \"nivel_socioec\")\n",
        "\n",
        "cat(\"Estimadores MCO (álgebra matricial):\\n\")\n",
        "print(beta_hat)"
      ]
    },
