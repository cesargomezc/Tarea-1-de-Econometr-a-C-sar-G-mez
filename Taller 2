      "cell_type": "markdown",
      "source": [
        "3. (15 puntos) Realiza un test de hipotesis para evaluar si las dos variables que se agregaron son\n",
        "significativas para el modelo simultaneamente. Use significancia del 5%."
      ],
      "metadata": {
        "id": "Kc-UK4VmV7fP"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ===================================================================\n",
        "# TEST DE HIPÓTESIS: SIGNIFICANCIA CONJUNTA (PRUEBA F)\n",
        "# ===================================================================\n",
        "\n",
        "# 1. Definición de los R-cuadrados (R2) de ambos modelos\n",
        "R2_ur <- 0.04059  # R2 del Modelo Irrestricto (con las dummies)\n",
        "R2_r  <- 0.03191  # R2 del Modelo Restringido (sin las dummies)\n",
        "\n",
        "# 2. Definición de parámetros para los grados de libertad\n",
        "n <- 209          # Número total de observaciones en la base ceosal1\n",
        "k <- 5            # Número de regresores en el modelo irrestricto\n",
        "q <- 2            # Número de restricciones (variables a evaluar)\n",
        "gl_den <- n-k-1   # Grados de libertad del denominador (203)\n",
        "\n",
        "# 3. Cálculo del Estadístico F empírico (F_est)\n",
        "# Fórmula: F = [ (R2_ur - R2_r) / q ] / [ (1 - R2_ur) / gl_den ]\n",
        "F_est <- ((R2_ur - R2_r) / q) / ((1 - R2_ur) / gl_den)\n",
        "\n",
        "# 4. Cálculo del Valor Crítico (F_critico) al 5% de significancia (alpha = 0.05)\n",
        "F_critico <- qf(0.95, df1 = q, df2 = gl_den)\n",
        "\n",
        "# 5. Visualización de los resultados en la consola\n",
        "cat(\"--- RESULTADOS DEL TEST DE HIPÓTESIS ---\\n\")\n",
        "cat(\"H0: Las variables añadidas (high_sales y high_sales_roe) son = 0\\n\")\n",
        "cat(\"H1: Al menos una de las variables es distinta de 0\\n\\n\")\n",
        "\n",
        "cat(\"Estadístico F calculado (F_est): \", round(F_est, 3), \"\\n\")\n",
        "cat(\"Valor Crítico (F_critico) al 5%: \", round(F_critico, 3), \"\\n\\n\")\n",
        "\n",
        "# 6. Regla de decisión y Conclusión\n",
        "if (F_est > F_critico) {\n",
        "  cat(\"DECISIÓN: Se rechaza H0 (\", round(F_est, 3), \">\", round(F_critico, 3), \")\\n\")\n",
        "  cat(\"CONCLUSIÓN: Las variables son significativas conjuntamente al 5%.\\n\")\n",
        "} else {\n",
        "  cat(\"DECISIÓN: No se rechaza H0 (\", round(F_est, 3), \"<\", round(F_critico, 3), \")\\n\")\n",
        "  cat(\"CONCLUSIÓN: Las variables NO son significativas conjuntamente al 5%.\\n\")\n",
        "}\n"
      ],
