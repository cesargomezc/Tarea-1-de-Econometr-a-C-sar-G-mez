      "source": [
        "# ===================================================================\n",
        "# TEST DE CHOW PARA MÚLTIPLES GRUPOS (POR SECTOR)\n",
        "# ===================================================================\n",
        "\n",
        "# 1. Creación de las submuestras\n",
        "ceosal1_indus    <- subset(ceosal1, indus == 1)\n",
        "ceosal1_finance  <- subset(ceosal1, finance == 1)\n",
        "ceosal1_consprod <- subset(ceosal1, consprod == 1)\n",
        "ceosal1_utility  <- subset(ceosal1, utility == 1)\n",
        "\n",
        "# 2. Estimación de los modelos\n",
        "modelo_r        <- lm(salary ~ sales + roe + ros, data = ceosal1) # Restringido\n",
        "modelo_indus    <- lm(salary ~ sales + roe + ros, data = ceosal1_indus)\n",
        "modelo_finance  <- lm(salary ~ sales + roe + ros, data = ceosal1_finance)\n",
        "modelo_consprod <- lm(salary ~ sales + roe + ros, data = ceosal1_consprod)\n",
        "modelo_utility  <- lm(salary ~ sales + roe + ros, data = ceosal1_utility)\n",
        "\n",
        "# 3. Cálculo de la Suma de Cuadrados de los Residuos (SSR)\n",
        "SSR_r        <- sum(residuals(modelo_r)^2)\n",
        "SSR_indus    <- sum(residuals(modelo_indus)^2)\n",
        "SSR_finance  <- sum(residuals(modelo_finance)^2)\n",
        "SSR_consprod <- sum(residuals(modelo_consprod)^2)\n",
        "SSR_utility  <- sum(residuals(modelo_utility)^2)\n",
        "\n",
        "SSR_ur <- SSR_indus + SSR_finance + SSR_consprod + SSR_utility\n",
        "\n",
        "# 4. Parámetros y Grados de Libertad\n",
        "G <- 4               # Número de grupos\n",
        "k <- 3               # Número de variables explicativas\n",
        "n <- nrow(ceosal1)   # Total de observaciones (209)\n",
        "\n",
        "gl1 <- (G - 1) * (k + 1)  # Numerador (12)\n",
        "gl2 <- n - (G * (k + 1))  # Denominador (193)\n",
        "\n",
        "# 5. Cálculo del Estadístico F y Valor Crítico al 5%\n",
        "F_est <- ((SSR_r - SSR_ur) / gl1) / (SSR_ur / gl2)\n",
        "F_critico <- qf(0.95, df1 = gl1, df2 = gl2)\n",
        "\n",
        "# 6. Visualización de los Resultados\n",
        "cat(\"--- RESULTADOS DEL TEST DE CHOW (MÚLTIPLES GRUPOS) ---\\n\")\n",
        "cat(\"H0: Los modelos son iguales para los 4 sectores.\\n\")\n",
        "cat(\"H1: Existen diferencias estructurales entre los sectores.\\n\\n\")\n",
        "\n",
        "cat(\"Estadístico F calculado (F_est): \", round(F_est, 3), \"\\n\")\n",
        "cat(\"Valor Crítico (F_critico) al 5%: \", round(F_critico, 3), \"\\n\\n\")\n",
        "\n",
        "# 7. Regla de Decisión\n",
        "if (F_est > F_critico) {\n",
        "  cat(\"DECISIÓN: Se rechaza H0 (\", round(F_est, 3), \">\", round(F_critico, 3), \")\\n\")\n",
        "  cat(\"CONCLUSIÓN: Existen diferencias estructurales estadísticamente significativas entre los sectores.\\n\")\n",
        "} else {\n",
        "  cat(\"DECISIÓN: No se rechaza H0 (\", round(F_est, 3), \"<\", round(F_critico, 3), \")\\n\")\n",
        "  cat(\"CONCLUSIÓN: NO existen diferencias estructurales significativas. Un modelo único es adecuado.\\n\")\n",
        "}"
