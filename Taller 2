      "cell_type": "code",
      "source": [
        "# ===================================================================\n",
        "# TEST DE CHOW: COMPARACIÓN DE GRUPOS (VENTAS ALTAS VS BAJAS)\n",
        "# ===================================================================\n",
        "\n",
        "# 1. Creación de variables de interacción (Dummies multiplicativas)\n",
        "# Asumiendo que 'sales_mayor_promedio' ya está creada en tu base 'ceosal1'\n",
        "ceosal1$sales_D <- ceosal1$sales * ceosal1$sales_mayor_promedio\n",
        "ceosal1$roe_D   <- ceosal1$roe * ceosal1$sales_mayor_promedio\n",
        "ceosal1$ros_D   <- ceosal1$ros * ceosal1$sales_mayor_promedio\n",
        "\n",
        "# 2. Definición de parámetros extraídos de los modelos\n",
        "R2_ur <- 0.06028  # R2 del modelo irrestricto (con las 4 nuevas variables)\n",
        "R2_r  <- 0.03191  # R2 del modelo restringido (base)\n",
        "n <- 209          # Observaciones totales\n",
        "k <- 7            # Regresores en el modelo irrestricto\n",
        "q <- 4            # Restricciones (la dummy + 3 interacciones)\n",
        "gl_den <- n - k - 1 # Grados de libertad del denominador (201)\n",
        "\n",
        "# 3. Cálculo del Estadístico F (F_est)\n",
        "F_est <- ((R2_ur - R2_r) / q) / ((1 - R2_ur) / gl_den)\n",
        "\n",
        "# 4. Cálculo del Valor Crítico (F_critico) al 5%\n",
        "F_critico <- qf(0.95, df1 = q, df2 = gl_den)\n",
